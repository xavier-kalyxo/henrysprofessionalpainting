---
// Utils
import { getImage } from "astro:assets";

// Components
import BaseLayout from "@layouts/BaseLayout.astro";
import Banner from "@components/Banner/Banner.astro";
import CTA from "@components/CTA/CTASimple.astro";

// Images
import landingImage from "@assets/images/services/henrys-professional-painting-interior-kitchen-cabinet-painting-espresso-brown.jpg";
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<BaseLayout title="Interior House Painting | Walls, Ceilings & Cabinets" description="Transform your home's interior with expert painting from Henry's Professional Painting. We handle walls, ceilings, trim, and cabinet painting in San Diego and La Mesa." heroImage={optimizedImage}>
	<Banner title="Interior House Painting" image={optimizedImage} />
	<!-- Page content goes here -->
	<CTA />
</BaseLayout>
