---
// Utils
import { getImage } from "astro:assets";

// Components
import BaseLayout from "@layouts/BaseLayout.astro";
import Banner from "@components/Banner/Banner.astro";
import CTA from "@components/CTA/CTASimple.astro";

// Images
import landingImage from "@assets/images/hero/henrys-professional-painting-hero-exterior-commercial-painting-1920w.jpeg";
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<BaseLayout title="Exterior Commercial Painting | Storefronts & Buildings" description="Make a strong first impression with professional exterior commercial painting. Henry's Professional Painting serves businesses throughout San Diego County." heroImage={optimizedImage}>
	<Banner title="Exterior Commercial Painting" image={optimizedImage} />
	<!-- Page content goes here -->
	<CTA />
</BaseLayout>
