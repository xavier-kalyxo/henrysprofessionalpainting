---
// Utils
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { isCurrentPage, getDropdownId } from "@js/utils.js";

// Data
import navData from "@data/navData.json";
import { BUSINESS } from "@data/client";
import henrysLogo from "@assets/images/henrys-logo.jpg";
---

<!-- ============================================ --><!--              Navigation                   --><!-- ============================================ -->
<style lang="less">
    /*-- -------------------------- -->
<---     Mobile Navigation      -->
<--- -------------------------- -*/

    /* Mobile - 1023px */
    @media only screen and (max-width: 1023.5px) {
        body {
            &.cs-open {
                overflow: hidden;
            }

            &.scroll {
                #cs-navigation {
                    transform: translateY(-3rem);

                    #dark-mode-toggle {
                        top: 0;
                        right: 0;
                    }
                }
            }
        }

        #cs-navigation {
            width: 100%;
            /* prevents padding from affecting height and width */
            box-sizing: border-box;
            padding: (12/16rem) (16/16rem) 0 (16/16rem);
            background-color: #fff;
            box-shadow: rgba(149, 157, 165, 0.2) 0px 8px 24px;
            position: fixed;
            z-index: 100;
            transition: transform 0.3s;

            &.cs-active {
                .cs-link {
                    color: var(--bodyTextColorWhite);
                }

                .cs-ul-wrapper {
                    opacity: 1;
                    transform: scaleY(1);
                    transition-delay: 0.1s;
                }

                .cs-li {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .cs-location {
                margin: 0;
                padding: 0;
                position: relative;
                z-index: -3;
                transition:
                    height 0.3s,
                    padding-bottom 0.3s,
                    opacity 0.3s;
            }

            .cs-top-social {
                display: none;
            }

            .cs-top-bar {
                padding-bottom: (12/16rem);
                position: relative;
                z-index: 1;

                &:before {
                    /* grey line */
                    content: "";
                    width: 100vw;
                    height: 1px;
                    background: #eff1f0;
                    opacity: 1;
                    display: block;
                    position: absolute;
                    bottom: 0;
                    left: 50%;
                    z-index: -2;
                    transform: translateX(-50%);
                    transition: opacity 0.3s;
                }
            }

            .cs-bottom-bar {
                height: auto;
                padding: (20/16rem) 0;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .cs-logo-wrapper {
                display: flex;
                flex-direction: column;
                align-items: center;
            }

            .cs-logo {
                width: auto;
                height: (65/16rem);
                display: block;

                img,
                svg {
                    width: auto;
                    height: 100%;
                    object-fit: contain;
                }
            }

            .cs-license {
                font-size: (10/16rem);
                line-height: 1;
                color: var(--bodyTextColor);
                margin-top: (2/16rem);
            }

            .cs-desktop {
                display: none;
            }

            .cs-item {
                font-size: (16/16rem);
                line-height: (24/16rem);
                list-style: none;
                margin: 0;
                color: #585b5d;
                display: flex;
                justify-content: center;
                align-items: center;
                gap: (4/16rem);
            }

            .cs-remove {
                display: none;
            }

            .cs-icon {
                width: (20/16rem);
                height: auto;
                display: block;
            }

            .cs-header {
                display: none;
            }

            .cs-link {
                font-size: (14/16rem);
                font-weight: 500;
                line-height: 1.5em;
                text-align: inherit;
                text-decoration: none;
                margin: 0;
                color: var(--bodyTextColor);
                display: block;
                transition: color 0.3s;
            }

            .cs-toggle {
                width: (48/16rem);
                height: (48/16rem);
                margin: 0;
                background-color: #f3f3f3;
                border: none;
                display: flex;
                justify-content: center;
                align-items: center;
            }

            .cs-active {
                .cs-line1 {
                    top: 50%;
                    transform: translate(-50%, -50%) rotate(225deg);
                }

                .cs-line2 {
                    top: 50%;
                    transform: translate(-50%, -50%) translateY(0)
                        rotate(-225deg);
                    transform-origin: center;
                }

                .cs-line3 {
                    opacity: 0;
                    bottom: 100%;
                }
            }

            .cs-box {
                width: (20/16rem);
                height: (12/16rem);
                position: relative;
            }

            .cs-line {
                width: 100%;
                height: 2px;
                background-color: #585b5d;
                border-radius: 2px;
                position: absolute;
                left: 50%;
                transform: translateX(-50%);
            }

            .cs-line1 {
                top: 0;
                transition:
                    transform 0.5s,
                    top 0.3s,
                    left 0.3s;
                animation-duration: 0.7s;
                animation-timing-function: ease;
                animation-direction: normal;
                animation-fill-mode: forwards;
                transform-origin: center;
            }

            .cs-line2 {
                top: 50%;
                transform: translateX(-50%) translateY(-50%);
                transition:
                    top 0.3s,
                    left 0.3s,
                    transform 0.5s;
                animation-duration: 0.7s;
                animation-timing-function: ease;
                animation-direction: normal;
                animation-fill-mode: forwards;
            }

            .cs-line3 {
                width: (12/16rem);
                bottom: 0;
                left: 0;
                transform: none;
                transition:
                    bottom 0.3s,
                    opacity 0.3s;
            }

            .cs-contact-wrapper,
            .cs-tablet,
            .cs-button-border {
                display: none;
            }
        }
    }

    /* Tablet - 650px - 1024px */
    @media only screen and (min-width: 650px) and (max-width: 1023.5px) {
        #cs-navigation {
            .cs-location {
                display: flex;
                flex-direction: row;
                justify-content: flex-end;
            }

            .cs-top-bar {
                padding-bottom: (12/16rem);
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .cs-logo-wrapper {
                margin-right: auto;
                order: 1;
            }

            .cs-item {
                position: relative;

                &:nth-of-type(2) {
                    &:after {
                        display: none;
                    }
                }

                &:after {
                    /* divider line */
                    content: "";
                    width: 1px;
                    height: 100%;
                    margin: 0 (16/16rem);
                    background: #cfd0d1;
                    opacity: 1;
                    display: block;
                    position: relative;
                }
            }

            .cs-top-social {
                height: (32/16rem);
                opacity: 1;
                display: flex;
                visibility: visible;
                justify-content: center;
                align-items: center;
                gap: (8/16rem);
                transition:
                    opacity 0.3s,
                    visibility 0.3s,
                    height 0.3s;
            }

            .cs-social-link {
                text-decoration: none;
                width: (32/16rem);
                height: (32/16rem);
                background-color: #f7f7f7;
                border-radius: 50%;
                display: flex;
                justify-content: center;
                align-items: center;
            }

            .cs-social-icon {
                width: (12/16rem);
                height: auto;
                opacity: 0.6;
                display: block;
            }

            .cs-bottom-bar {
                gap: (16/16rem);
            }

            .cs-li-link {
                font-size: (24/16rem);
            }

            .cs-nav-button {
                text-decoration: none;
                margin-right: (32/16rem);
                display: flex;
                justify-content: flex-start;
                align-items: center;
                order: 2;
                gap: (16/16rem);
                position: relative;
                transform-style: preserve-3d;
                perspective: 200px;

                &:hover {
                    .cs-wrapper {
                        transform: rotateY(180deg);
                    }
                }

                .cs-wrapper {
                    width: (40/16rem);
                    height: (40/16rem);
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    position: relative;
                    z-index: 1;
                    transition: transform 0.6s;
                    /* prevents flexbox from squishing it */
                    flex: none;

                    &:before {
                        /* backgorund color in pseudo so we can use the primary color variable and use opacity */
                        content: "";
                        width: 100%;
                        height: 100%;
                        background-color: #f3f3f3;
                        display: block;
                        position: absolute;
                        top: 0;
                        left: 0;
                        z-index: -1;
                    }
                }

                .cs-icon {
                    width: (24/16rem);
                    height: auto;
                    display: block;
                    transition: transform 0.3s;
                }

                .cs-info {
                    display: flex;
                    flex-direction: column;
                    align-items: flex-start;
                }

                .cs-header {
                    font-size: (14/16rem);
                    font-weight: 500;
                    line-height: 1.5em;
                    margin: 0;
                    color: #585b5d;
                    display: block;
                }

                .cs-link-content {
                    font-size: (16/16rem);
                    font-weight: 700;
                    line-height: 1.5em;
                    margin: 0;
                    color: var(--headerColor);
                    display: block;
                }
            }

            .cs-nav {
                order: 4;
            }
        }
    }

    /* Inbetween - 1024px */
    @media only screen and (min-width: 1024px) {
        #cs-navigation {
            .cs-bottom-bar {
                padding: 0;
                justify-content: flex-start;
            }

            .cs-remove {
                display: flex;
            }

            .cs-toggle {
                display: none;
            }

            // .cs-nav {
            // 	order: 2;
            // }

            .cs-ul {
                width: 100%;
                margin: 0;
                padding: 0;
                display: flex;
                justify-content: flex-start;
                align-items: center;
                /* 20px - 36px */
                gap: clamp(1.25rem, 2.6vw, 2.25rem);
            }

            .cs-li {
                list-style: none;
                /* 24px - 28px */
                padding: clamp(1.5rem, 2.1vw, 1.75rem) 0;
                /* prevent flexbox from squishing it */
                flex: none;
                &:last-of-type {
                    /* pushes the button to the far roght */
                    margin-left: auto;
                    padding: 0;
                }
            }

            .cs-li-link {
                font-size: (16/16rem);
                font-weight: 500;
                line-height: 1.5em;
                text-transform: uppercase;
                text-decoration: none;
                margin: 0;
                color: var(--headerColor);
                display: block;
                position: relative;
                transition: color 0.3s;

                &.cs-active,
                &:hover {
                    color: var(--primary);
                }
            }

            .cs-nav-button {
                display: none;
            }
        }
    }

    /* Small Desktop - 1024px */
    @media only screen and (max-width: 1023.5px) {
        #cs-navigation {
            .cs-ul-wrapper {
                width: 100%;
                height: 100vh;
                background-color: #fff;
                overflow: hidden;
                box-shadow: inset rgba(0, 0, 0, 0.2) 0px 8px 24px;
                opacity: 0;
                position: absolute;
                top: 100%;
                left: 0;
                z-index: -1;
                transform: scaleY(0);
                transition:
                    transform 0.4s,
                    opacity 0.3s;
                transform-origin: top;
            }

            .cs-ul {
                width: 100%;
                height: auto;
                max-height: 65vh;
                margin: 0;
                padding: (48/16rem) 0 (48/16rem) 0;
                overflow: scroll;
                display: flex;
                flex-direction: column;
                justify-content: flex-start;
                align-items: center;
                gap: (20/16rem);
            }

            .cs-li {
                text-align: center;
                list-style: none;
                width: 100%;
                margin-right: 0;
                opacity: 0;
                /* transition from these values */
                transform: translateY(-4.375rem);
                transition:
                    transform 0.6s,
                    opacity 0.9s;

                &:nth-of-type(1) {
                    transition-delay: 0.05s;
                }
                &:nth-of-type(2) {
                    transition-delay: 0.1s;
                }
                &:nth-of-type(3) {
                    transition-delay: 0.15s;
                }
                &:nth-of-type(4) {
                    transition-delay: 0.2s;
                }
                &:nth-of-type(5) {
                    transition-delay: 0.25s;
                }
                &:nth-of-type(6) {
                    transition-delay: 0.3s;
                }
                &:nth-of-type(7) {
                    transition-delay: 0.35s;
                }
                &:nth-of-type(8) {
                    transition-delay: 0.4s;
                }
                &:nth-of-type(9) {
                    transition-delay: 0.45s;
                }
            }

            .cs-li-link {
                /* 16px - 24px */
                font-size: clamp(1rem, 2.5vw, 1.5rem);
                font-weight: 500;
                line-height: 1.2em;
                text-transform: uppercase;
                text-decoration: none;
                margin: 0;
                color: var(--headerColor);
                display: inline-block;
                position: relative;

                &:before {
                    /* active state underline */
                    content: "";
                    width: 100%;
                    height: 1px;
                    background: currentColor;
                    opacity: 1;
                    display: none;
                    position: absolute;
                    bottom: (-2/16rem);
                    left: 0;
                }

                &.cs-active {
                    &:before {
                        display: block;
                    }
                }
            }
        }
    }

    /*-- -------------------------- -->
<---     Navigation Dropdown    -->
<--- -------------------------- -*/

    /* Mobile - 1023px */
    @media only screen and (max-width: 1023.5px) {
        #cs-navigation {
            .cs-li {
                text-align: center;
                width: 100%;
                display: block;
            }

            .cs-dropdown {
                color: var(--bodyTextColorWhite);
                position: relative;

                .cs-dropdown-toggle {
                    text-align: inherit;
                    /* Reset default button styles */
                    background: none;
                    cursor: pointer;
                    border: none;
                    /* Remove any default focus styles */
                    -webkit-appearance: none;
                    -moz-appearance: none;
                    appearance: none;
                }
                &.cs-active {
                    .cs-drop-ul {
                        height: auto;
                        margin: (12/16rem) auto 0 auto;
                        padding: (20/16rem) 0;
                        opacity: 1;
                        visibility: visible;
                    }

                    .cs-drop-link {
                        opacity: 1;
                    }
                }

                .cs-li-link {
                    position: relative;
                    transition: opacity 0.3s;
                }
            }

            .cs-drop-icon {
                width: (24/16rem);
                height: auto;
                position: absolute;
                top: 50%;
                right: (-20/16rem);
                transform: translateY(-50%);
            }

            .cs-drop-ul {
                width: 70%;
                height: 0;
                margin: 0 auto;
                padding: 0;
                background-color: var(--primary);
                overflow: hidden;
                opacity: 0;
                display: flex;
                visibility: hidden;
                flex-direction: column;
                justify-content: flex-start;
                align-items: center;
                gap: (12/16rem);
                transition:
                    padding 0.3s,
                    margin 0.3s,
                    height 0.3s,
                    opacity 0.3s,
                    visibility 0.3s;
            }

            .cs-drop-li {
                list-style: none;
            }

            .cs-li-link {
                &.cs-drop-link {
                    /* 14px - 16px */
                    font-size: clamp(0.875rem, 2vw, 1.25rem);
                    text-transform: uppercase;
                    color: #fff;
                }
            }
        }
    }

    /* Desktop - 1024px */
    @media only screen and (min-width: 1024px) {
        #cs-navigation {
            .cs-dropdown {
                position: relative;

                &:hover,
                &.cs-active {
                    cursor: pointer;
                    .cs-drop-ul {
                        opacity: 1;
                        visibility: visible;
                        transform: scaleY(1);
                    }

                    .cs-drop-li {
                        opacity: 1;
                        transform: translateY(0);
                    }
                }
            }

            .cs-drop-icon {
                width: (24/16rem);
                height: auto;
                display: inline-block;
            }

            .cs-drop-ul {
                min-width: (200/16rem);
                margin: 0;
                padding: 0;
                background-color: #fff;
                overflow: hidden;
                box-shadow: rgba(149, 157, 165, 0.2) 0px 10px 16px;
                opacity: 0;
                border-bottom: 5px solid var(--primary);
                visibility: hidden;
                /* if you have 8 or more links in your dropdown nav, uncomment the columns property to make the list into 2 even columns. Change it to 3 or 4 if you need extra columns. Then remove the transition delays on the cs-drop-li so they don't have weird scattered animations */
                // columns: 2;
                position: absolute;
                top: calc(100% - 2px);
                z-index: 100;
                transform: scaleY(0);
                transition:
                    transform 0.3s,
                    visibility 0.3s,
                    opacity 0.3s;
                transform-origin: top;
            }

            .cs-drop-li {
                font-size: (16/16rem);
                text-decoration: none;
                list-style: none;
                width: 100%;
                height: auto;
                color: var(--bodyTextColor);
                opacity: 0;
                display: block;
                transform: translateY(-10/16rem);
                transition:
                    opacity 0.6s,
                    transform 0.6s;

                &:nth-of-type(2) {
                    transition-delay: 0.15s;
                }
                &:nth-of-type(3) {
                    transition-delay: 0.3s;
                }
                &:nth-of-type(4) {
                    transition-delay: 0.45s;
                }
                &:nth-of-type(5) {
                    transition-delay: 0.6s;
                }
                &:nth-of-type(6) {
                    transition-delay: 0.75s;
                }
            }

            .cs-dropdown-toggle {
                text-align: inherit;
                /* Reset default button styles */
                background: none;
                cursor: pointer;
                border: none;
                /* Remove any default focus styles */
                -webkit-appearance: none;
                -moz-appearance: none;
                appearance: none;
            }

            .cs-li-link {
                display: flex;
                align-items: center;
                &.cs-drop-link {
                    font-size: (16/16rem);
                    line-height: 1.5em;
                    text-decoration: none;
                    white-space: nowrap;
                    /* prevents padding from affecting height and width */
                    box-sizing: border-box;
                    padding: (12/16rem);
                    color: var(--bodyTextColor);
                    display: block;
                    transition:
                        color 0.3s,
                        background-color 0.3s;

                    &:hover {
                        background-color: #f7f7f7;
                    }

                    &:before {
                        display: none;
                    }

                    &:focus-visible {
                        outline-offset: -2px;
                    }
                }
            }
        }
    }

    /*-- -------------------------- -->
<---     Desktop Navigation     -->
<--- -------------------------- -*/

    /* Small Desktop - 1024px */
    @media only screen and (min-width: 1024px) {
        body.scroll {
            #cs-navigation {
                .cs-top-bar {
                    height: 0;
                    overflow: hidden;
                    opacity: 0;
                    &:before {
                        width: 0;
                    }
                }

                .cs-middle {
                    height: (80/16rem);
                }

                .cs-logo-wrapper,
                .cs-contact-wrapper {
                    height: (80/16rem);
                }

                .cs-logo {
                    img {
                        max-height: (75/16rem);
                        object-fit: contain;
                    }
                }

                .cs-license {
                    font-size: (10/16rem);
                }

                .cs-toggle {
                    margin-top: 0;
                }
            }
        }

        #cs-navigation {
            /* tall enough to fit logo at max-height 8.25rem + padding */
            --headerHeight: 9.5rem;

            width: 100%;
            /* prevents padding from affecting height and width */
            box-sizing: border-box;
            padding: 0;
            background-color: #fff;
            box-shadow: rgba(149, 157, 165, 0.2) 0px 8px 24px;
            display: flex;
            position: fixed;
            z-index: 10000;
            transition:
                height 0.3s,
                background-color 0.3s;

            .cs-toggle {
                display: none;
            }

            .cs-logo-wrapper {
                width: 20%;
                max-width: (340/16rem);
                height: var(--headerHeight);
                box-sizing: border-box;
                padding: (8/16rem);
                border-right: 1px solid #e7e7e8;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                z-index: 100;
                transition: height 0.3s;
            }

            .cs-logo {
                display: flex;
                justify-content: center;
                align-items: center;

                img,
                svg {
                    width: 100%;
                    max-width: (280/16rem);
                    height: auto;
                    max-height: (132/16rem);
                    box-sizing: border-box;
                    object-fit: contain;
                    transition:
                        max-height 0.3s,
                        opacity 0.3s,
                        transform 0.6s;
                }
            }

            .cs-license {
                font-size: (12/16rem);
                line-height: 1;
                color: var(--bodyTextColor);
                margin-top: (4/16rem);
                display: block;
                transition: font-size 0.3s, opacity 0.3s;
            }

            .cs-mobile {
                display: none;
            }

            .cs-top-bar {
                width: 100%;
                height: (56/16rem);
                margin: 0;
                padding: 0;
                display: flex;
                justify-content: space-between;
                align-items: center;
                position: relative;
                transition:
                    height 0.3s,
                    opacity 0.3s,
                    transform 0.3s;

                &:before {
                    /* grey line */
                    content: "";
                    height: 1px;
                    background: #e7e7e8;
                    opacity: 1;
                    display: block;
                    position: absolute;
                    right: (-40/16rem);
                    bottom: 0;
                    left: (-40/16rem);
                    z-index: -2;
                    transition: width 0.3s;
                }
            }

            .cs-top-social {
                height: (32/16rem);
                opacity: 1;
                display: flex;
                visibility: visible;
                justify-content: center;
                align-items: center;
                gap: (8/16rem);
                transition:
                    opacity 0.3s,
                    visibility 0.3s,
                    height 0.3s;
            }

            .cs-social-link {
                text-decoration: none;
                width: (32/16rem);
                height: (32/16rem);
                background-color: #f7f7f7;
                border-radius: 50%;
                display: flex;
                justify-content: center;
                align-items: center;
                transition: background-color 0.3s;

                &:hover {
                    background-color: var(--primary);
                }
            }

            .cs-social-icon {
                width: (12/16rem);
                height: auto;
                opacity: 0.6;
                display: block;
            }

            .cs-location {
                display: flex;
                flex-direction: row;
            }

            .cs-item {
                list-style: none;
                margin: 0;
                display: flex;
                justify-content: flex-start;
                align-items: center;
                gap: (4/16rem);
                position: relative;
                flex: none;
                &:last-of-type {
                    &:after {
                        display: none;
                    }
                }

                &:hover {
                    .cs-picture {
                        transform: scale(1.1);
                    }
                }

                &:after {
                    /* divider line */
                    content: "";
                    width: 1px;
                    height: 100%;
                    /* 24px - 44px */
                    margin: 0 (24/16rem);
                    background: #eff1f0;
                    opacity: 1;
                    display: block;
                    position: relative;
                }
            }

            .cs-remove {
                display: none;
            }

            .cs-link {
                font-size: (14/16rem);
                line-height: 1.5em;
                text-align: inherit;
                text-decoration: none;
                margin: 0;
                color: var(--bodyTextColor);
                display: block;
                transition: color 0.3s;
                &:hover {
                    text-decoration: underline;
                }
            }

            .cs-middle {
                width: 100%;
                height: var(--headerHeight);
                padding: 0 (40/16rem) 0 (40/16rem);
                transition: height 0.3s;
            }

            .cs-nav {
                order: -1;
            }

            .cs-bottom-bar {
                width: 100%;
                /* prevents padding from affecting height and width */
                box-sizing: border-box;
                display: flex;
                justify-content: flex-end;
                align-items: center;
                gap: (32/16rem);
                position: relative;
            }

            .cs-desktop-button {
                text-decoration: none;
                display: flex;
                justify-content: flex-start;
                align-items: center;
                order: 2;
                gap: (16/16rem);
                position: relative;
                transform-style: preserve-3d;
                perspective: 200px;

                &:hover {
                    .cs-wrapper {
                        transform: rotateY(360deg);
                    }
                }
            }

            .cs-wrapper {
                width: (56/16rem);
                height: (56/16rem);
                display: flex;
                justify-content: center;
                align-items: center;
                position: relative;
                z-index: 1;
                transition: transform 0.6s;
                /* prevents flexbox from squishing it */
                flex: none;

                &:before {
                    /* backgorund color in pseudo so we can use the primary color variable and use opacity */
                    content: "";
                    width: 100%;
                    height: 100%;
                    background-color: #f3f3f3;
                    display: block;
                    position: absolute;
                    top: 0;
                    left: 0;
                    z-index: -1;
                }
            }

            .cs-button-icon {
                width: (20/16rem);
                height: auto;
                display: block;
                transition: transform 0.3s;
            }

            .cs-info {
                display: flex;
                flex-direction: column;
                align-items: flex-start;
            }

            .cs-header {
                font-size: (14/16rem);
                font-weight: 500;
                line-height: 1.5em;
                margin: 0;
                color: #585b5d;
                display: block;
            }

            .cs-link-content {
                font-size: (16/16rem);
                font-weight: 700;
                line-height: 1.5em;
                margin: 0;
                color: var(--headerColor);
                display: block;
            }

            .cs-nav-button,
            .cs-button-border {
                display: none;
            }

            .cs-contact-wrapper {
                width: 21%;
                max-width: (294/16rem);
                height: var(--headerHeight);
                border-left: 1px solid #e7e7e8;
                display: flex;
                justify-content: center;
                align-items: center;
                transition: height 0.3s;
                flex: none;
            }
        }
    }

    /* Small Desktop - 1500px */
    @media only screen and (min-width: 1500px) {
        #cs-navigation {
            .cs-nav {
                margin-right: auto;
            }

            .cs-button-border {
                font-size: (16/16rem);
                line-height: (46/16rem);
                text-transform: uppercase;
                text-decoration: none;
                margin-right: (48/16rem);
                padding: 0 (28/16rem);
                color: var(--headerColor);
                border: 1px solid var(--headerColor);
                display: flex;
                justify-content: center;
                align-items: center;
                gap: (10/16rem);
                transition:
                    color 0.3s,
                    background-color 0.3s;

                &:hover {
                    background-color: var(--headerColor);
                    color: #fff;
                    .cs-icon {
                        filter: grayscale(1) brightness(1000%);
                    }
                }

                .cs-icon {
                    width: (20/16rem);
                }
            }

            .cs-remove {
                display: flex;
            }
        }
    }
</style>

