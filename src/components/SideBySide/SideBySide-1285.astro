---
import { Image } from "astro:assets";
import photo1 from "@assets/photos/henrys-professional-painting-content-home-01-1920w.webp";
import photo2 from "@assets/photos/henrys-professional-painting-content-home-05-1920w.webp";
import photo3 from "@assets/photos/henrys-professional-painting-content-home-03-1920w.webp";
import photo4 from "@assets/photos/henrys-professional-painting-content-home-04-1920w.webp";
import photo5 from "@assets/photos/henrys-professional-painting-content-home-06-1920w.webp";
import photo6 from "@assets/photos/henrys-professional-painting-content-home-08-1920w.webp";
---

<!-- ============================================ --><!--                Side By Side                  --><!-- ============================================ -->
<section id="sbs-1285">
    <div class="cs-container">
        <div class="cs-image-group">
            <div class="cs-picture cs-picture1">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo1}
                    alt="freshly painted Spanish-style home exterior in La Mesa"
                    width={244}
                    height={200}
                />
            </div>
            <div class="cs-picture cs-picture2">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo2}
                    alt="beautifully painted living room interior with warm tones"
                    width={244}
                    height={270}
                />
            </div>
            <div class="cs-picture cs-picture3">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo3}
                    alt="freshly painted modern multi-unit residential building exterior"
                    width={244}
                    height={270}
                />
            </div>
            <div class="cs-picture cs-picture4">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo4}
                    alt="commercial building exterior painting project in San Diego"
                    width={310}
                    height={343}
                />
            </div>
            <div class="cs-picture cs-picture5">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo5}
                    alt="freshly painted bedroom with clean neutral walls"
                    width={244}
                    height={270}
                />
            </div>
            <div class="cs-picture cs-picture6">
                <Image
                    loading="lazy"
                    decoding="async"
                    src={photo6}
                    alt="professionally painted commercial storefront exterior"
                    width={244}
                    height={190}
                />
            </div>
            <!--Stripe background-->
            <picture class="cs-waves-wrapper">
                <img
                    class="cs-waves"
                    loading="lazy"
                    decoding="async"
                    src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Graphics/svg-waves.svg"
                    alt=""
                    width="650"
                    height="933"
                    aria-hidden="true"
                />
            </picture>
        </div>
        <div class="cs-content">
            <span class="cs-topper">Our Specialization</span>
            <h2 class="cs-title">
                Professional Painting for Your Home or Business
            </h2>
            <p class="cs-text">
                At Henry's Professional Painting, we pride ourselves on
                delivering exceptional painting services to the La Mesa and
                greater San Diego, CA area. Established in 1987, our
                family-owned business has grown through dedication,
                craftsmanship, and a commitment to customer satisfaction.
                Whether it's a fresh coat of paint for your home's interior or a
                vibrant new look for your business's exterior, our team of
                licensed, insured, and bonded professionals ensures every
                project is completed with precision and care.
            </p>
            <p class="cs-text">
                Our expertise spans residential and commercial painting, with
                services tailored to meet the unique needs of each customer. We
                offer free color consultations to help you choose the perfect
                palette and eco-friendly solutions that are kind to the
                environment. With over 37 years of experience, we understand the
                importance of personalized service and attention to detail. From
                the first stroke to the final touch, we're here to turn your
                vision into reality, providing a seamless experience from start
                to finish.
            </p>
            <a href="/contact/" class="cs-button-solid">Get in Touch</a>
        </div>
    </div>
</section>

<style lang="less">
    /*-- -------------------------- -->
<---       Side By Side         -->
<--- -------------------------- -*/

    /* Mobile - 360px */
    @media only screen and (min-width: 0rem) {
        #sbs-1285 {
            padding: var(--sectionPadding);
            background-color: #f7f7f7;
            overflow: hidden;

            .cs-container {
                width: 100%;
                /* changes to 1280px at desktop */
                max-width: (550/16rem);
                margin: auto;
                display: flex;
                flex-direction: column;
                align-items: center;
                /* 48px - 64px */
                gap: clamp(3rem, 6vw, 4rem);
            }

            .cs-content {
                /* set text align to left if content needs to be left aligned */
                text-align: left;
                width: 100%;
                max-width: (522/16rem);
                display: flex;
                flex-direction: column;
                /* centers content horizontally, set to flex-start to left align */
                align-items: flex-start;
            }

            .cs-text {
                margin-bottom: (16/16rem);
                &:last-of-type {
                    margin-bottom: (32/16rem);
                }
            }

            .cs-ul {
                max-width: (630/16rem);
                margin: 0 0 (32/16rem) 0;
                padding: 0;
                /* clips the bullets to create the half circle */
                overflow: hidden;
                display: flex;
                flex-direction: column;
                align-items: flex-start;
                gap: (12/16rem);
            }

            .cs-li {
                list-style: none;
                margin: 0;
                color: var(--bodyTextColor);
                display: flex;
                justify-content: flex-start;
                align-items: flex-start;
                gap: (12/16rem);
                position: relative;
            }

            .cs-button-solid {
                font-size: (16/16rem);
                /* 46px - 56px */
                line-height: clamp(2.875rem, 5.5vw, 3.5rem);
                text-decoration: none;
                font-weight: 700;
                text-align: center;
                margin: 0;
                color: #fff;
                min-width: (150/16rem);
                padding: 0 (24/16rem);
                background-color: var(--primary);
                border-radius: (4/16rem);
                display: inline-block;
                position: relative;
                z-index: 1;
                /* prevents padding from adding to the width */
                box-sizing: border-box;

                &:before {
                    content: "";
                    position: absolute;
                    height: 100%;
                    width: 0%;
                    background: #000;
                    opacity: 1;
                    top: 0;
                    left: 0;
                    z-index: -1;
                    border-radius: (4/16rem);
                    transition: width 0.3s;
                }

                &:hover {
                    &:before {
                        width: 100%;
                    }
                }
            }

            .cs-image-group {
                /* scales the whole group based on the view width size and stop when that vales equals .845em, resets at desktop */
                font-size: ~"min(2.207vw, 1em)";
                width: (545/16em);
                height: (793/16em);
                display: block;
                position: relative;
                z-index: 1;
            }

            .cs-picture {
                border-radius: (8/16em);
                overflow: hidden;
                position: absolute;

                img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    position: absolute;
                    top: 0;
                    left: 0;
                }
            }

            .cs-picture1 {
                width: (244/16em);
                height: (200/16em);
                top: (0/16em);
                left: (0/16em);
            }

            .cs-picture2 {
                width: (244/16em);
                height: (270/16em);
                top: (40/16em);
                right: (33/16em);
            }

            .cs-picture3 {
                width: (244/16em);
                height: (270/16em);
                top: (220/16em);
                left: 0;
            }

            .cs-picture4 {
                width: (310/16em);
                height: (343/16em);
                box-shadow: 0px 24px 52px 0px rgba(0, 0, 0, 0.38);
                top: (294/16em);
                right: 0;
                z-index: 10;
            }

            .cs-picture5 {
                width: (244/16em);
                height: (270/16em);
                top: (510/16em);
                left: (0/16em);
            }

            .cs-picture6 {
                width: (244/16em);
                height: (190/16em);
                bottom: (0/16em);
                right: (33/16em);
            }

            .cs-waves-wrapper {
                /* changes to 100% at desktop */
                width: 100vw;
                height: 150%;
                position: absolute;
                bottom: 0;
                left: 50%;
                z-index: -1;
                /* changes at desktop */
                transform: translateX(-50%);

                img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    position: absolute;
                    top: 0;
                    left: 0;
                }
            }
        }
    }

    /* Small Desktop - 1024px */
    @media only screen and (min-width: 64rem) {
        #sbs-1285 {
            .cs-container {
                max-width: (1280/16rem);
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
            }

            .cs-content {
                padding: (100/16rem) 0;
                align-self: center;
            }

            .cs-image-group {
                font-size: ~"min(1.2vw, 1em)";
                flex: none;
            }

            .cs-picture1 {
                border-radius: 0 0 (16/16rem) (16/16rem);
            }

            .cs-picture6 {
                border-radius: 0;
            }

            .cs-waves-wrapper {
                width: 110%;
                height: 100%;
                left: 50%;
                bottom: 50%;
                transform: translate(-50%, 50%);
            }
        }
    }

    /* Large Desktop - 1200px */
    @media only screen and (min-width: 75rem) {
        #sbs-1285 {
            .cs-container {
                padding-left: (88/16rem);
                /* prevents padding and border from affecting height and width */
                box-sizing: border-box;
            }

            .cs-waves-wrapper {
                width: (692/16rem);
                height: initial;
                left: (-88/16rem);
                top: 0;
                bottom: 0;
                transform: none;
            }
        }
    }
</style>
